# All optional. Leave JWT_SECRET / ADMIN_PASSWORD empty to let the app generate a
# persistent random secret and a random admin password (printed to logs on first boot).
# Set them to pin your own values.
JWT_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
PORT=6880
# New windows open in <WORKSPACE_ROOT>/<username>/<groupname> (created automatically).
# Leave empty to use tmux's default working directory.
WORKSPACE_ROOT=
